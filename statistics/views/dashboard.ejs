<h2>Security Scans Dashboard</h2>
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <p style="color: #666; margin: 0;">
    Showing <%= scans.length %> scan<%= scans.length !== 1 ? 's' : '' %>
  </p>
  <% if (scans.length > 0) { %>
    <button onclick="deleteAllScans()" class="btn" style="background-color: #c00; color: white;">
      Delete All Scans
    </button>
  <% } %>
</div>

<% if (scans.length === 0) { %>
  <div class="empty-state">
    <p style="font-size: 18px; margin-bottom: 10px;">No scans yet</p>
    <p>Scans will appear here when the plugin submits security findings to the server.</p>
  </div>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Scan ID</th>
        <th>Timestamp</th>
        <th>Project Name</th>
        <th>Client IP</th>
        <th>Total Findings</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% scans.forEach(scan => { %>
        <tr>
          <td><code>#<%= scan.id %></code></td>
          <td><%= new Date(scan.timestamp).toLocaleString() %></td>
          <td><strong><%= scan.project_name || 'Unknown' %></strong></td>
          <td><code><%= scan.client_ip || 'N/A' %></code></td>
          <td>
            <% if (scan.total_findings === 0) { %>
              <span class="badge badge-gray"><%= scan.total_findings %></span>
            <% } else if (scan.total_findings < 5) { %>
              <span class="badge badge-yellow"><%= scan.total_findings %></span>
            <% } else { %>
              <span class="badge badge-red"><%= scan.total_findings %></span>
            <% } %>
          </td>
          <td>
            <a href="/admin/scan/<%= scan.id %>" class="btn" style="padding: 6px 12px; font-size: 12px;">
              View Details
            </a>
            <button onclick="deleteScan(<%= scan.id %>)" class="btn" style="padding: 6px 12px; font-size: 12px; background-color: #c00; color: white; margin-left: 5px;">
              Delete
            </button>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (hasPrevPage) { %>
        <a href="/admin?page=<%= currentPage - 1 %>" class="btn btn-secondary">← Previous</a>
      <% } %>

      <span style="padding: 10px; color: #666;">
        Page <%= currentPage %> of <%= totalPages %>
      </span>

      <% if (hasNextPage) { %>
        <a href="/admin?page=<%= currentPage + 1 %>" class="btn btn-secondary">Next →</a>
      <% } %>
    </div>
  <% } %>
<% } %>

<script>
async function deleteScan(scanId) {
  const confirmed = await showConfirm(
    'Are you sure you want to delete this scan? This action cannot be undone.',
    'Delete Scan',
    { icon: '🗑️', confirmText: 'Delete', danger: true }
  );

  if (!confirmed) return;

  try {
    const response = await fetch(`/admin/api/scan/${scanId}`, {
      method: 'DELETE'
    });

    const data = await response.json();

    if (data.success) {
      await showAlert('Scan deleted successfully', 'Success', '✓');
      window.location.reload();
    } else {
      await showAlert('Error deleting scan: ' + (data.error || 'Unknown error'), 'Error', '❌');
    }
  } catch (error) {
    await showAlert('Error deleting scan: ' + error.message, 'Error', '❌');
  }
}

async function deleteAllScans() {
  const confirmed1 = await showConfirm(
    'Are you sure you want to delete ALL scans? This action cannot be undone.',
    'Delete All Scans',
    { icon: '🗑️', confirmText: 'Continue', danger: true }
  );

  if (!confirmed1) return;

  const confirmed2 = await showConfirm(
    'This will permanently delete all scans and their findings. Are you absolutely sure?',
    'Final Confirmation',
    { icon: '⚠️', confirmText: 'Delete All', danger: true }
  );

  if (!confirmed2) return;

  try {
    const response = await fetch('/admin/api/scans', {
      method: 'DELETE'
    });

    const data = await response.json();

    if (data.success) {
      await showAlert(`${data.count} scan(s) deleted successfully`, 'Success', '✓');
      window.location.reload();
    } else {
      await showAlert('Error deleting scans: ' + (data.error || 'Unknown error'), 'Error', '❌');
    }
  } catch (error) {
    await showAlert('Error deleting scans: ' + error.message, 'Error', '❌');
  }
}
</script>
