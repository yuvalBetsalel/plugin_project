# Server Environment Configuration Template

# Copy this file to .env in the server/ directory when running locally
# For Fly.io deployment, set these as secrets via dashboard or flyctl

# ============================================
# IMPORTANT: NEVER COMMIT ACTUAL .env FILE
# ============================================
# This .env.example is safe to commit (no secrets)
# Your actual .env file should be in .gitignore

# Server Configuration
PORT=3000
NODE_ENV=development

# Security Secrets
# Generate with: npm run generate-secrets
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=
SESSION_SECRET=
SESSION_EXPIRY_HOURS=24

# Database Configuration
DATABASE_PATH=./server-data/security.db
DATABASE_TYPE=sqlite

# For Production PostgreSQL (optional)
# DATABASE_TYPE=postgresql
# DATABASE_HOST=your-db-host.com
# DATABASE_PORT=5432
# DATABASE_NAME=security_db
# DATABASE_USER=your-db-user
# DATABASE_PASSWORD=your-db-password

# ============================================
# Deployment Notes
# ============================================

# LOCAL DEVELOPMENT:
# 1. Copy this file: cp .env.example .env
# 2. Run: npm run generate-secrets
# 3. Paste generated keys into .env
# 4. Start server: npm start

# FLY.IO DEPLOYMENT:
# DO NOT create a .env file on Fly.io
# Instead, set secrets via:
#   flyctl secrets set ADMIN_API_KEY=<generated-key>
#   flyctl secrets set SESSION_SECRET=<generated-secret>
# Other env vars are configured in fly.toml

# SECURITY:
# - ADMIN_API_KEY: Used to access admin dashboard
# - SESSION_SECRET: Used for session cookie signing
# - Both should be 64+ character random strings
# - Rotate these every 90 days in production
